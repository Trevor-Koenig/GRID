@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "External Logins";
    ViewData["Subtitle"] = "Manage your linked external accounts";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<partial name="_StatusMessage" for="StatusMessage" />

@if (Model.CurrentLogins?.Count > 0)
{
    <div class="admin-panel-card mb-4">
        <div class="admin-panel-header">
            <span>Linked Accounts</span>
            <span class="admin-panel-count">@Model.CurrentLogins.Count</span>
        </div>
        <div class="p-3">
            @foreach (var login in Model.CurrentLogins)
            {
                <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                    <span class="fw-semibold">@login.ProviderDisplayName</span>
                    @if (Model.ShowRemoveButton)
                    {
                        <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                            <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                            <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
}

@if (Model.OtherLogins?.Count > 0)
{
    <div class="admin-panel-card">
        <div class="admin-panel-header">
            <span>Add Another Account</span>
        </div>
        <div class="p-4">
            <form id="link-login-form" asp-page-handler="LinkLogin" method="post">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var provider in Model.OtherLogins)
                    {
                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                name="provider" value="@provider.Name">
                            @provider.DisplayName
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
}
