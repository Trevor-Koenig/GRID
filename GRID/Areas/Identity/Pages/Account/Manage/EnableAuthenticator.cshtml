@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure Authenticator";
    ViewData["Subtitle"] = "Set up your two-factor authentication app";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="admin-panel-card mb-4">
    <div class="admin-panel-header">
        <span>Step 1 — Install an app</span>
    </div>
    <div class="p-4">
        <p class="mb-2">Download an authenticator app if you don't already have one:</p>
        <ul class="mb-0">
            <li>
                Microsoft Authenticator —
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072" target="_blank">Android</a>,
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073" target="_blank">iOS</a>
            </li>
            <li>
                Google Authenticator —
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2" target="_blank">Android</a>,
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605" target="_blank">iOS</a>
            </li>
        </ul>
    </div>
</div>

<div class="admin-panel-card mb-4">
    <div class="admin-panel-header">
        <span>Step 2 — Scan or enter the key</span>
    </div>
    <div class="p-4">
        <p>Scan the QR code below, or manually enter the key into your authenticator app. Spaces and casing do not matter.</p>
        <div class="d-flex align-items-start gap-4 flex-wrap">
            <div id="qrCode" class="flex-shrink-0"></div>
            <div>
                <div class="text-muted mb-1" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:.05em;">Manual key</div>
                <kbd class="d-inline-block px-3 py-2" style="font-size:1rem;letter-spacing:.1em;">@Model.SharedKey</kbd>
            </div>
        </div>
        <div id="qrCodeData" data-url="@Model.AuthenticatorUri" class="d-none"></div>
    </div>
</div>

<div class="admin-panel-card">
    <div class="admin-panel-header">
        <span>Step 3 — Verify the code</span>
    </div>
    <div class="p-4">
        <p>Enter the 6-digit code shown in your authenticator app to confirm setup.</p>
        <form id="send-code" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            <div class="form-floating mb-3" style="max-width:300px;">
                <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="000000" />
                <label asp-for="Input.Code">Verification code</label>
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Verify &amp; Enable</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript" src="~/lib/qrcode.js"></script>
    <script type="text/javascript" src="~/js/qr.js"></script>
}
