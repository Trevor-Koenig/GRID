@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="admin-panel-card">
    <div class="admin-panel-header">
        <span>Settings</span>
    </div>
    <div class="p-2">
        <ul class="list-unstyled mb-0">
            <li>
                <a class="d-block px-2 py-1 rounded docs-nav-link @ManageNavPages.IndexNavClass(ViewContext)"
                   id="profile" asp-page="./Index">Profile</a>
            </li>
            <li>
                <a class="d-block px-2 py-1 rounded docs-nav-link @ManageNavPages.EmailNavClass(ViewContext)"
                   id="email" asp-page="./Email">Email</a>
            </li>
            <li>
                <a class="d-block px-2 py-1 rounded docs-nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)"
                   id="change-password" asp-page="./ChangePassword">Password</a>
            </li>
            <li>
                <a class="d-block px-2 py-1 rounded docs-nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)"
                   id="two-factor" asp-page="./TwoFactorAuthentication">Two-Factor Auth</a>
            </li>
            @if (hasExternalLogins)
            {
                <li>
                    <a class="d-block px-2 py-1 rounded docs-nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)"
                       id="external-logins" asp-page="./ExternalLogins">External Logins</a>
                </li>
            }
            <li>
                <a class="d-block px-2 py-1 rounded docs-nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)"
                   id="personal-data" asp-page="./PersonalData">Personal Data</a>
            </li>
        </ul>
    </div>
</div>
