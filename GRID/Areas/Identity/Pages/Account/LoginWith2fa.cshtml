@page
@model LoginWith2faModel
@{
    ViewData["Title"] = "Two-factor authentication";
}

<div class="auth-bg">
    <img src="~/images/hero/bannerDarkReduced.webp" class="dark-theme auth-bg-img" alt="">
    <img src="~/images/hero/bannerLightReduced.webp" class="light-theme auth-bg-img" alt="">
    <div class="auth-bg-overlay"></div>
    <div class="auth-card-wrapper">
        <div class="auth-card">
            <a href="/" class="auth-logo">
                <h1 class="sitename">GR1ID<span>.</span></h1>
            </a>
            <h2>Two-factor authentication</h2>
            <p class="text-muted mb-3" style="font-size:0.9rem;">Enter the code from your authenticator app to continue.</p>
            <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                <input asp-for="RememberMe" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.TwoFactorCode" class="form-control" autocomplete="off" placeholder="000000" />
                    <label asp-for="Input.TwoFactorCode" class="form-label">Authenticator code</label>
                    <span asp-validation-for="Input.TwoFactorCode" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMachine" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMachine" />
                        @Html.DisplayNameFor(m => m.Input.RememberMachine)
                    </label>
                </div>
                <button type="submit" class="w-100 btn btn-lg btn-primary mb-3">Verify</button>
                <div class="d-flex flex-column gap-1">
                    <a asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">Use a recovery code instead</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
