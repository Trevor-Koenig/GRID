@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend Email Confirmation";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="auth-bg">
    <div class="auth-card-wrapper">
        <div class="auth-card">
            <a asp-page="/Index" class="auth-logo">
                <h1 class="sitename">GR<span>I</span>D</h1>
            </a>
            <h2 class="fs-5 fw-semibold mb-1">Resend confirmation email</h2>
            <p class="text-muted mb-4" style="font-size:0.9rem;">Enter your email address and we'll send a new confirmation link.</p>

            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="your@email.com" />
                    <label asp-for="Input.Email">Email address</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100">Send confirmation email</button>
            </form>

            <div class="d-flex justify-content-center mt-3" style="font-size:0.85rem;">
                <a asp-page="./Login">Back to sign in</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
