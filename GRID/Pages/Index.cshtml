@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Pages/Index.js" asp-append-version="true"></script>
}

<!-- Hero Section -->
<section id="home" class="hero section dark-background">

    <img src="~/images/hero/bannerDarkReduced.webp" class="dark-theme" alt="GRID homelab dashboard banner" data-aos="fade-in">
    <img src="~/images/hero/bannerLightReduced.webp" class="light-theme" alt="GRID homelab dashboard banner" data-aos="fade-in">

    <div class="container">

        <div class="row justify-content-center text-center" data-aos="fade-up" data-aos-delay="100">
            <div class="col-xl-6 col-lg-8">
                <h2>General Resource & Integration Dashboard<span>.</span></h2>
                <p>Everything I build - all in one GRID</p>
            </div>
        </div>

        <div class="row gy-4 mt-5 justify-content-center" data-aos="fade-up" data-aos-delay="200">
            @foreach (var svc in Model.HeroServices)
            {
                <div class="col-xl-2 col-md-4 col-6 div-link" data-aos="fade-up" data-aos-delay="300" data-href="/go/@svc.Token">
                    <div class="icon-box">
                        <i class="@(svc.IconClass ?? "bi bi-box-arrow-up-right")"></i>
                        <h3>@svc.Name</h3>
                    </div>
                </div>
            }
            <div class="col-xl-2 col-md-4 col-6 div-link" data-aos="fade-up" data-aos-delay="600" data-href="/#about">
                <div class="icon-box">
                    <i class="bi bi-card-list"></i>
                    <h3>About Me</h3>
                </div>
            </div>
        </div>

    </div>

</section><!-- /Hero Section -->
<!-- About Section -->
<section id="about" class="about section">

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4">
            <div class="col-lg-6 order-1 order-lg-2">
                <img src="~/images/about.jpg" class="img-fluid" alt="">
            </div>
            <div class="col-lg-6 order-2 order-lg-1 content">
                <h3>A Website Built to Empower</h3>
                <p class="fst-italic">
                    Welcome to GRID, a General Resource & Integration Dashboard, designed to be powerful and quick to load so that you
                    can spend less time trying to find what you need and more time doing it.
                </p>
                <ul>
                    <li><i class="bi bi-check2-all"></i> <span>Designed with a mobile first approach.</span></li>
                    <li><i class="bi bi-check2-all"></i> <span>Thoughtfully placed links so you never spend more time here than you want.</span></li>
                    <li><i class="bi bi-check2-all"></i> <span>Modern and fast approach. Assets on this website have been reduced so that they load as quickly as possible.</span></li>
                </ul>
                <p>
                    Building web applications has been a hobby of mine for quite some time now. I published this website
                    so that I could more easily share the tools I have been building with family and friends. However,
                    I also wanted to take this opportunity to stretch my legs and show the world what kind of website
                    I can develop.
                </p>
            </div>
        </div>

    </div>

</section><!-- /About Section -->
<!-- Clients Section -->
<section id="toolbox" class="clients section">

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="swiper init-swiper">
            <script type="application/json" class="swiper-config">
                {
                  "loop": true,
                  "speed": 600,
                  "autoplay": {
                    "delay": 5000
                  },
                  "slidesPerView": "auto",
                  "pagination": {
                    "el": ".swiper-pagination",
                    "type": "bullets",
                    "clickable": true
                  },
                  "breakpoints": {
                    "320": {
                      "slidesPerView": 2,
                      "spaceBetween": 40
                    },
                    "480": {
                      "slidesPerView": 3,
                      "spaceBetween": 60
                    },
                    "640": {
                      "slidesPerView": 4,
                      "spaceBetween": 80
                    },
                    "992": {
                      "slidesPerView": 6,
                      "spaceBetween": 120
                    }
                  }
                }
            </script>
            <div class="swiper-wrapper align-items-center">
                <div class="swiper-slide"><img src="~/images/carousel/asp-net.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/c-sharp.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/docker-logo.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/javascript.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/postgresql.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/truenas-inverted.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/html5.png" class="img-fluid" alt=""></div>
                <div class="swiper-slide"><img src="~/images/carousel/bootstrap.png" class="img-fluid" alt=""></div>
            </div>
            <div class="swiper-pagination"></div>
        </div>

    </div>

</section><!-- /Clients Section -->
<!-- Features Section -->
<section id="features" class="features section">

    <div class="container">

        <div class="row gy-4">
            <div class="features-image col-lg-6" data-aos="fade-up" data-aos-delay="100"><img src="~/images/features.jpg" alt=""></div>
            <div class="col-lg-6">

                <div class="features-item d-flex ps-0 ps-lg-3 pt-4 pt-lg-0" data-aos="fade-up" data-aos-delay="200">
                    <i class="bi bi-hdd flex-shrink-0"></i>
                    <div>
                        <h4>Network Attached Storage</h4>
                        <p>Store all your files in a remote cloud to be accessed anywhere, anytime</p>
                    </div>
                </div><!-- End Features Item-->

                <div class="features-item d-flex mt-5 ps-0 ps-lg-3" data-aos="fade-up" data-aos-delay="300">
                    <i class="bi bi-cloud-moon-fill flex-shrink-0"></i>
                    <div>
                        <h4>Image and Recipe backups</h4>
                        <p>Sleep safe knowing your images and recipes are automatically backed-up to the cloud</p>
                    </div>
                </div><!-- End Features Item-->

                <div class="features-item d-flex mt-5 ps-0 ps-lg-3" data-aos="fade-up" data-aos-delay="400">
                    <i class="bi bi-boxes flex-shrink-0"></i>
                    <div>
                        <h4>Manage Game Servers</h4>
                        <p>Manage and access hosted game servers all through an online UI</p>
                    </div>
                </div><!-- End Features Item-->

                <div class="features-item d-flex mt-5 ps-0 ps-lg-3" data-aos="fade-up" data-aos-delay="500">
                    <i class="bi bi-camera-reels flex-shrink-0"></i>
                    <div>
                        <h4>Watch Movies and Shows</h4>
                        <p>Stream or download movies and shows to your device to be watched anywhere</p>
                    </div>
                </div><!-- End Features Item-->

            </div>
        </div>

    </div>

</section><!-- /Features Section -->
<!-- Services Section -->
<section id="services" class="services section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>Services</h2>
        <p>Tools and apps running on my homelab</p>
    </div><!-- End Section Title -->

    <div class="container">

        <div class="row gy-4">

            @{ var svcDelay = 100; }
            @foreach (var svc in Model.ServicesSection)
            {
                var status = Model.GetServiceStatus(svc.Token);
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@svcDelay">
                    <div class="service-item position-relative">
                        <div class="icon">
                            <i class="@(svc.IconClass ?? "bi bi-box-arrow-up-right")"></i>
                        </div>
                        <a href="/go/@svc.Token" class="stretched-link">
                            <h3>@svc.Name</h3>
                        </a>
                        <p>@svc.Description</p>
                        @if (status != null)
                        {
                            <p class="mb-0 small @(status.IsUp ? "text-success" : "text-danger")">
                                <i class="bi bi-circle-fill me-1" style="font-size:0.5em; vertical-align:middle;"></i>
                                @(status.IsUp ? "Online" : "Offline")
                            </p>
                        }
                    </div>
                </div><!-- End Service Item -->
                svcDelay += 100;
            }

            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@svcDelay">
                <div class="service-item position-relative">
                    <div class="icon">
                        <i class="bi bi-chat-square-text"></i>
                    </div>
                    <a href="~/#contact" class="stretched-link">
                        <h3>Request Web Services</h3>
                    </a>
                    <p>Want a new way to edit documents, or a more private LLM? Contact me and we will discuss how to add it.</p>
                </div>
            </div><!-- End Service Item -->

        </div>

    </div>

</section><!-- /Services Section -->
<!-- Call To Action Section -->
<section id="call-to-action" class="call-to-action section dark-background">

    <img src="~/lib/gp-1.0.0/dist/img/cta-bg.jpg" alt="">

    <div class="container">
        <div class="row justify-content-center" data-aos="zoom-in" data-aos-delay="100">
            <div class="col-xl-10">
                <div class="text-center">
                    <h3>Make your Web Application</h3>
                    <p>You deserve a website that's as stunning, seamless, and effective as this one. Whether you're starting from scratch or refining an existing idea, I can help you build a web application that reflects your vision and meets your goals. Get in touch, and together we'll create something truly impactful.</p>
                    <a class="cta-btn" href="~/#contact">Request Quote</a>
                </div>
            </div>
        </div>
    </div>

</section><!-- /Call To Action Section -->

<!-- Contact Section -->
<section id="contact" class="contact section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>Contact</h2>
        <p>Contact Me</p>
    </div><!-- End Section Title -->

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row gy-4 justify-content-center">
            <div class="col-lg-8">
                @if (Model.ContactSent)
                {
                    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" data-aos="fade-up">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Your message has been sent. Thank you!</span>
                    </div>
                }
                <form method="post" asp-page-handler="Contact" class="contact-form" data-aos="fade-up" data-aos-delay="200">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row gy-4">

                        <div class="col-md-6">
                            <input asp-for="ContactInput.Name" class="form-control" placeholder="Your Name" />
                            <span asp-validation-for="ContactInput.Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <input asp-for="ContactInput.Email" class="form-control" placeholder="Your Email" />
                            <span asp-validation-for="ContactInput.Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <input asp-for="ContactInput.Subject" class="form-control" placeholder="Subject" />
                            <span asp-validation-for="ContactInput.Subject" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <textarea asp-for="ContactInput.Message" class="form-control" placeholder="Message" style="height:150px;"></textarea>
                            <span asp-validation-for="ContactInput.Message" class="text-danger"></span>
                        </div>

                        <div class="col-md-12 text-center">
                            <button type="submit">Send Message</button>
                        </div>

                    </div>
                </form>
            </div><!-- End Contact Form -->

        </div>

    </div>

</section><!-- /Contact Section -->