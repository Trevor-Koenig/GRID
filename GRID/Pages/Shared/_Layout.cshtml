@inject GRID.Data.ApplicationDbContext _layoutDb
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> _layoutUserManager
@inject GRID.Services.IServiceStatusService _statusService
@inject GRID.Services.PermissionService _permissionService
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService _authorizationService
@{
    string? userTheme = null;
    if (User.Identity?.IsAuthenticated == true)
    {
        var uid = _layoutUserManager.GetUserId(User);
        var profile = uid != null ? await _layoutDb.UserProfiles.FindAsync(uid) : null;
        userTheme = profile?.Theme;
    }
    var navLinks = await _layoutDb.ServiceLinks
        .Where(s => s.IsActive && s.ShowInNav)
        .OrderBy(s => s.DisplayOrder)
        .ToListAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GRID - @ViewData["Title"]</title>
    @if (userTheme != null)
    {
        <meta name="user-theme" content="@userTheme" />
    }
    <script type="importmap"></script>
    <!-- Favicons -->
    <link href="~/images/favicon/favicon-32x32.png" rel="icon">
    <link href="~/images/favicon/apple-touch-icon.png" rel="apple-touch-icon">
    <!-- Vendor CSS Files -->
    <link href="~/lib/gp-1.0.0/dist/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/lib/gp-1.0.0/dist/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/lib/gp-1.0.0/dist/vendor/aos/aos.css" rel="stylesheet">
    <link href="~/lib/gp-1.0.0/dist/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
    <link href="~/lib/gp-1.0.0/dist/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <!-- Bootstrap default stlyes -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Custom stylesheets -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GRID.styles.css" asp-append-version="true" />
    <!-- GP-1.0.0 Stylsheet -->
    <link href="~/lib/gp-1.0.0/dist/css/main.css" rel="stylesheet" />
    <!-- Cutsom Icons (WHAATTT??)-->
    <link href="~/css/CustomIcons.css" rel="stylesheet" />
</head>
<body>
    <header id="header" class="header d-flex align-items-center fixed-top">
        <div class="container-fluid position-relative align-items-center justify-content-between">

            <div class="row">
                <div class="col d-flex align-items-center justify-content-center">

                    <a href="/" class="logo d-flex align-items-center me-auto me-lg-0">
                        <!-- Uncomment the line below if you also wish to use an image logo -->
                        <!-- <img src="~/lib/gp-1.0.0/dist/img/logo.png" alt=""> -->
                        <h1 class="sitename">GRID</h1>
                        <span>.</span>
                    </a>
                </div>
                <div class="col">
                    <nav id="navmenu" class="navmenu d-flex justify-content-xl-center justify-content-end">
                        <ul>
                            <li><a href="/#home" class="active">Home<br></a></li>
                            <li><a href="/#about">About</a></li>
                            <li><a href="/#services">Services</a></li>
                            <li><a href="/#contact">Contact</a></li>
                            <li><a asp-page="/Docs/Index">Docs</a></li>
                            <li class="dropdown">
                                <a href="#"><span>Quick Services</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                                <ul>
                                    @foreach (var svc in navLinks)
                                    {
                                        <li>
                                            <a href="/go/@svc.Token">
                                                @svc.Name
                                                @{
                                                    var st = _statusService.GetStatus(svc.Token);
                                                }
                                                @if (st != null)
                                                {
                                                    <span class="nav-status-dot nav-status-dot--@(st.IsUp ? "up" : "down")"></span>
                                                }
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                            @if ((await _authorizationService.AuthorizeAsync(User, null, "AdminOnly")).Succeeded)
                            {
                            <li class="dropdown">
                                <a href="#"><span>Admin</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                                <ul>
                                    <li><a asp-page="/Admin/Dashboard/Index">Dashboard</a></li>
                                    @if ((await _permissionService.UserHasPermissionAsync(User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value), GRID.Models.Permissions.AdminUsers))){ <li><a asp-page="/Admin/Users/Index">Users</a></li> }
                                    @if ((await _permissionService.UserHasPermissionAsync(User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value), GRID.Models.Permissions.AdminRoles))){ <li><a asp-page="/Admin/Roles/Index">Roles</a></li> <li><a asp-page="/Admin/RolePermissions/Index">Permissions</a></li> }
                                    @if ((await _permissionService.UserHasPermissionAsync(User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value), GRID.Models.Permissions.AdminInvites))){ <li><a asp-page="/Admin/Invites/Index">Invites</a></li> }
                                    @if ((await _permissionService.UserHasPermissionAsync(User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value), GRID.Models.Permissions.AdminContacts))){ <li><a asp-page="/Admin/ContactRequests/Index">Contact Requests</a></li> }
                                    @if ((await _permissionService.UserHasPermissionAsync(User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value), GRID.Models.Permissions.AdminServices))){ <li><a asp-page="/Admin/Services/Index">Services</a></li> }
                                    @if ((await _permissionService.UserHasPermissionAsync(User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value), GRID.Models.Permissions.AdminAuditLog))){ <li><a asp-page="/Admin/AuditLog/Index">Audit Log</a></li> }
                                </ul>
                            </li>
                            }
                            <li class="d-xl-none my-4"><a></a></li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="d-xl-none"><a asp-area="Identity" asp-page="/Account/Manage/Index">Account</a></li>
                                <li class="d-xl-none">
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                                        <button type="submit" class="nav-link-btn">Log Out</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="d-xl-none"><a asp-area="Identity" asp-page="/Account/Login">Log In</a></li>
                            }
                            <li class="d-xl-none">
                                <a class="theme-dark-btn light-theme">Dark Mode</a>
                            </li>
                            <li class="d-xl-none">
                                <a class="theme-light-btn dark-theme">Light Mode</a>
                            </li>
                        </ul>
                        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
                    </nav>
                </div>
                <div class="col-lg d-xl-flex d-none justify-content-center align-items-center">
                        @await Html.PartialAsync("_MiniNavPartial")
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        @RenderBody()
    </main>

    <footer id="footer" class="footer dark-background">
    </footer>

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <!-- Preloader -->
    <div id="preloader"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Vendor JS Files -->
    <script src="~/lib/gp-1.0.0/dist/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/php-email-form/validate.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/aos/aos.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/lib/gp-1.0.0/dist/vendor/purecounter/purecounter_vanilla.js"></script>

    <!-- Main JS File -->
    <script src="~/lib/gp-1.0.0/dist/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            var pageLoadTime = Date.now();
            document.addEventListener('visibilitychange', function () {
                if (document.visibilityState === 'hidden') {
                    var duration = Math.round((Date.now() - pageLoadTime) / 1000);
                    navigator.sendBeacon('/api/page-duration', new Blob(
                        [JSON.stringify({ path: location.pathname, duration: duration })],
                        { type: 'application/json' }
                    ));
                }
            });
        })();
    </script>
</body>
</html>
