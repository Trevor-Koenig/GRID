@model string

@if (Model != null)
{
    var isError = Model.StartsWith("Error", StringComparison.OrdinalIgnoreCase);
    <div class="alert alert-@(isError ? "danger" : "success") alert-dismissible mb-3" role="alert">
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        @Model
    </div>
}
