@page "{category}/{slug}"
@model GRID.Pages.Docs.ArticleModel
@{
    ViewData["Title"] = Model.EditMode ? $"Editing: {Model.Article.Title}" : Model.Article.Title;
    var sidebarDict = new Dictionary<string, List<GRID.Models.DocArticle>>(StringComparer.OrdinalIgnoreCase);
    foreach (var a in Model.SidebarArticles)
    {
        var key = a.Category.Trim().ToLower();
        if (!sidebarDict.ContainsKey(key)) sidebarDict[key] = new();
        sidebarDict[key].Add(a);
    }
    var sidebarGroups = sidebarDict.OrderBy(kv => kv.Key);
}

@if (Model.EditMode)
{
    @section Styles {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css" />
        <style>
            /* Theme EasyMDE to match the site's CSS variables */
            .EasyMDEContainer .CodeMirror {
                background: var(--background-color);
                color: var(--default-color);
                border-color: color-mix(in srgb, var(--default-color) 15%, transparent);
                font-family: var(--bs-font-monospace);
                font-size: 0.9rem;
                min-height: 500px;
            }
            .EasyMDEContainer .editor-toolbar {
                background: color-mix(in srgb, var(--default-color) 5%, var(--background-color));
                border-color: color-mix(in srgb, var(--default-color) 15%, transparent);
            }
            .EasyMDEContainer .editor-toolbar button {
                color: var(--default-color) !important;
            }
            .EasyMDEContainer .editor-toolbar button.active,
            .EasyMDEContainer .editor-toolbar button:hover {
                background: color-mix(in srgb, var(--default-color) 12%, transparent);
                border-color: color-mix(in srgb, var(--default-color) 25%, transparent);
            }
            .EasyMDEContainer .editor-toolbar i.separator {
                border-color: color-mix(in srgb, var(--default-color) 20%, transparent);
            }
            .EasyMDEContainer .CodeMirror-cursor {
                border-left-color: var(--default-color);
            }
            .EasyMDEContainer .CodeMirror-selected { background: color-mix(in srgb, var(--accent-color) 30%, transparent); }
            .EasyMDEContainer .editor-preview,
            .EasyMDEContainer .editor-preview-side {
                background: var(--background-color);
                color: var(--default-color);
                border-color: color-mix(in srgb, var(--default-color) 15%, transparent);
            }
            .EasyMDEContainer .editor-statusbar {
                color: color-mix(in srgb, var(--default-color) 55%, transparent);
            }
            /* Remove double border with the panel card */
            .EasyMDEContainer { border: none; }
            .EasyMDEContainer .CodeMirror { border-left: none; border-right: none; border-bottom: none; border-radius: 0; }
            .EasyMDEContainer .editor-toolbar { border-left: none; border-right: none; border-top: none; border-radius: 0; }
            .EasyMDEContainer .editor-statusbar { padding: 6px 16px; }
        </style>
    }
}

<section class="section">
    <div class="container" data-aos="fade-up">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span>Categories</span>
                        @if (Model.IsAdmin)
                        {
                            <a asp-page="/Docs/Index" class="btn btn-outline-secondary btn-sm" style="font-size:0.75rem;">All Docs</a>
                        }
                    </div>
                    <div class="p-2">
                        @foreach (var group in sidebarGroups)
                        {
                            <div class="mb-3">
                                <div class="fw-semibold px-2 py-1" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:.05em;opacity:.6;">@group.Key</div>
                                <ul class="list-unstyled mb-0">
                                    @foreach (var article in group.Value)
                                    {
                                        var isActive = article.Id == Model.Article.Id;
                                        <li>
                                            <a asp-page="/Docs/Article"
                                               asp-route-category="@article.Category.ToLower()"
                                               asp-route-slug="@article.Slug"
                                               class="d-block px-2 py-1 rounded docs-nav-link @(isActive ? "docs-nav-link--active" : "") @(Model.IsAdmin && !article.IsPublished ? "fst-italic" : "")">
                                                @article.Title
                                                @if (!article.IsPublic)
                                                {
                                                    <span class="ms-1 badge bg-secondary" style="font-size:0.6rem;">Private</span>
                                                }
                                                @if (Model.IsAdmin && !article.IsPublished)
                                                {
                                                    <span class="ms-1 badge bg-warning text-dark" style="font-size:0.6rem;">Draft</span>
                                                }
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
                @if (!Model.IsAdmin)
                {
                    <div class="mt-3">
                        <a asp-page="/Docs/Index" class="admin-back-link">All Docs</a>
                    </div>
                }
            </div>

            <!-- Content area -->
            <div class="col-lg-9">

                @if (Model.EditMode)
                {
                    <!-- Edit mode: form left, preview right -->
                    <form method="post" asp-page-handler="Save">
                        <input type="hidden" name="id" value="@Model.Article.Id" />

                        <!-- Metadata row -->
                        <div class="admin-panel-card mb-3">
                            <div class="admin-panel-header">
                                <span>Editing Article</span>
                                <div class="d-flex gap-2">
                                    <a asp-page="/Docs/Article"
                                       asp-route-category="@Model.Article.Category.ToLower()"
                                       asp-route-slug="@Model.Article.Slug"
                                       class="btn btn-sm btn-outline-secondary">View</a>
                                    <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                </div>
                            </div>
                            <div class="p-3">
                                <div class="row g-3">
                                    <div class="col-md-5">
                                        <div class="form-floating">
                                            <input type="text" class="form-control" id="editTitle" name="title" value="@Model.Article.Title" placeholder="Title" required />
                                            <label for="editTitle">Title</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-floating">
                                            <input type="text" class="form-control" id="editCategory" name="category"
                                                   value="@Model.Article.Category" placeholder="Category" required
                                                   list="categoryList" autocomplete="off" />
                                            <label for="editCategory">Category</label>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-floating">
                                            <input type="text" class="form-control" id="editSlug" name="slug" value="@Model.Article.Slug" placeholder="slug" required />
                                            <label for="editSlug">Slug</label>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-floating">
                                            <input type="number" class="form-control" id="editOrder" name="displayOrder" value="@Model.Article.DisplayOrder" placeholder="0" />
                                            <label for="editOrder">Order</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-floating">
                                            <input type="text" class="form-control" id="editToken" name="serviceToken" value="@Model.Article.ServiceToken" placeholder="token" />
                                            <label for="editToken">Service token (optional)</label>
                                        </div>
                                    </div>
                                    <div class="col-md-8 d-flex align-items-center gap-4 ps-3">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="editPublished" name="isPublished" value="true" @(Model.Article.IsPublished ? "checked" : "") />
                                            <label class="form-check-label" for="editPublished">Published</label>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="editPublic" name="isPublic" value="true" @(Model.Article.IsPublic ? "checked" : "") />
                                            <label class="form-check-label" for="editPublic">Public</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Rich text editor -->
                        <div class="admin-panel-card">
                            <div class="admin-panel-header"><span>Content</span></div>
                            <div class="p-0">
                                <textarea id="contentEditor" name="content">@Model.Article.Content</textarea>
                            </div>
                        </div>

                        <datalist id="categoryList">
                            @foreach (var cat in sidebarDict.Keys.OrderBy(k => k))
                            {
                                <option value="@cat"></option>
                            }
                        </datalist>

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <a asp-page="/Docs/Article"
                               asp-route-category="@Model.Article.Category.ToLower()"
                               asp-route-slug="@Model.Article.Slug"
                               class="btn btn-sm btn-outline-secondary">Discard &amp; View</a>
                            <button type="submit" class="btn btn-primary btn-sm">Save</button>
                        </div>
                    </form>
                }
                else
                {
                    <!-- View mode -->
                    <div class="admin-panel-card">
                        <div class="admin-panel-header">
                            <span>
                                @Model.Article.Title
                                @if (!Model.Article.IsPublic)
                                {
                                    <span class="ms-2 badge bg-secondary" style="font-size:0.7rem;">Private</span>
                                }
                                @if (Model.IsAdmin && !Model.Article.IsPublished)
                                {
                                    <span class="ms-2 badge bg-warning text-dark" style="font-size:0.7rem;">Draft</span>
                                }
                            </span>
                            <div class="d-flex align-items-center gap-3">
                                <span class="admin-panel-count">@Model.Article.Category</span>
                                @if (Model.IsAdmin)
                                {
                                    <a asp-page="/Docs/Article"
                                       asp-route-category="@Model.Article.Category.ToLower()"
                                       asp-route-slug="@Model.Article.Slug"
                                       asp-route-edit="true"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                }
                            </div>
                        </div>
                        <div class="p-4 docs-content">
                            @Html.Raw(Model.RenderedContent)
                        </div>
                        <div class="admin-panel-footer">
                            <span class="text-muted" style="font-size:0.8rem;">
                                Last updated @Model.Article.UpdatedAt.ToString("MMMM d, yyyy")
                            </span>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>

@if (Model.EditMode)
{
    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
        <script>
            var easyMDE = new EasyMDE({
                element: document.getElementById('contentEditor'),
                spellChecker: false,
                autosave: { enabled: false },
                status: ['lines', 'words'],
                toolbar: [
                    'bold', 'italic', 'strikethrough', 'heading', '|',
                    'quote', 'unordered-list', 'ordered-list', '|',
                    'link', 'image', 'table', 'code', 'horizontal-rule', '|',
                    'preview', 'side-by-side', 'fullscreen', '|',
                    'undo', 'redo', 'guide'
                ],
                previewClass: ['docs-content'],
                renderingConfig: { singleLineBreaks: false }
            });
        </script>
    }
}
