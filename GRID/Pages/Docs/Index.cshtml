@page
@model GRID.Pages.Docs.IndexModel
@{
    ViewData["Title"] = "Documentation";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Documentation</h2>
        <p>Guides and reference material</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span>Categories</span>
                        @if (Model.IsAdmin)
                        {
                            <button type="button" class="btn btn-primary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#createDocModal">
                                New Article
                            </button>
                        }
                    </div>
                    <div class="p-2">
                        @foreach (var group in Model.GroupedArticles)
                        {
                            <div class="mb-3">
                                <div class="fw-semibold px-2 py-1" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:.05em;opacity:.6;">@group.Key</div>
                                <ul class="list-unstyled mb-0">
                                    @foreach (var article in group)
                                    {
                                        <li class="d-flex align-items-center">
                                            <a asp-page="/Docs/Article"
                                               asp-route-category="@article.Category.ToLower()"
                                               asp-route-slug="@article.Slug"
                                               class="flex-grow-1 px-2 py-1 rounded docs-nav-link @(!article.IsPublished ? "text-muted fst-italic" : "")">
                                                @article.Title
                                                @if (!article.IsPublic)
                                                {
                                                    <span class="ms-1 badge bg-secondary" style="font-size:0.65rem;">Private</span>
                                                }
                                                @if (Model.IsAdmin && !article.IsPublished)
                                                {
                                                    <span class="ms-1 badge bg-warning text-dark" style="font-size:0.65rem;">Draft</span>
                                                }
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                        @if (!Model.GroupedArticles.Any())
                        {
                            <p class="text-muted px-2 py-1 mb-0" style="font-size:0.9rem;">No articles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Main content -->
            <div class="col-lg-9">
                @if (!Model.GroupedArticles.Any())
                {
                    <div class="admin-panel-card">
                        <div class="admin-panel-empty">
                            <p>No documentation has been published yet.</p>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var group in Model.GroupedArticles)
                    {
                        <div class="mb-4">
                            <h4 class="mb-3">@group.Key</h4>
                            <div class="row gy-3">
                                @foreach (var article in group)
                                {
                                    <div class="col-md-6">
                                        <div class="admin-panel-card h-100 docs-card @(!article.IsPublished ? "opacity-50" : "")">
                                            <div class="p-3">
                                                <div class="d-flex align-items-start justify-content-between gap-2">
                                                    <a asp-page="/Docs/Article"
                                                       asp-route-category="@article.Category.ToLower()"
                                                       asp-route-slug="@article.Slug"
                                                       class="fw-semibold text-decoration-none flex-grow-1">
                                                        @article.Title
                                                    </a>
                                                    @if (Model.IsAdmin)
                                                    {
                                                        <div class="d-flex gap-2 flex-shrink-0">
                                                            <a asp-page="/Docs/Article"
                                                               asp-route-category="@article.Category.ToLower()"
                                                               asp-route-slug="@article.Slug"
                                                               asp-route-edit="true"
                                                               class="admin-action-link btn btn-link p-0">
                                                                <i class="bi bi-pencil"></i>
                                                            </a>
                                                            <button type="button" class="admin-action-link btn btn-link p-0"
                                                                    data-bs-toggle="modal" data-bs-target="#deleteDocModal"
                                                                    data-doc-id="@article.Id"
                                                                    data-doc-title="@article.Title">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="d-flex gap-2 mt-1 flex-wrap">
                                                    @if (!article.IsPublic)
                                                    {
                                                        <span class="badge bg-secondary" style="font-size:0.65rem;">Private</span>
                                                    }
                                                    @if (Model.IsAdmin && !article.IsPublished)
                                                    {
                                                        <span class="badge bg-warning text-dark" style="font-size:0.65rem;">Draft</span>
                                                    }
                                                    <span class="text-muted" style="font-size:0.8rem;">Updated @article.UpdatedAt.ToString("MMM d, yyyy")</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

        </div>
    </div>
</section>

@if (Model.IsAdmin)
{
    <!-- Create Article Modal -->
    <div class="modal fade" id="createDocModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content admin-modal-content">
                <form method="post" asp-page-handler="Create">
                    <div class="modal-header admin-modal-header">
                        <h5 class="modal-title">New Article</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="createTitle" name="title" placeholder="Title" required />
                                    <label for="createTitle">Title</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="createCategory" name="category" placeholder="Category" required />
                                    <label for="createCategory">Category</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="createSlug" name="slug" placeholder="slug" required pattern="[a-z0-9\-]+" />
                                    <label for="createSlug">Slug</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="createServiceToken" name="serviceToken" placeholder="Service token" />
                                    <label for="createServiceToken">Service token (optional)</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="createDisplayOrder" name="displayOrder" value="0" placeholder="0" />
                                    <label for="createDisplayOrder">Display order</label>
                                </div>
                            </div>
                            <div class="col-md-3 d-flex flex-column justify-content-center gap-2 ps-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="createIsPublished" name="isPublished" value="true" />
                                    <label class="form-check-label" for="createIsPublished">Published</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="createIsPublic" name="isPublic" value="true" checked />
                                    <label class="form-check-label" for="createIsPublic">Public</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer admin-modal-footer">
                        <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-sm">Create &amp; Edit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Article Modal -->
    <div class="modal fade" id="deleteDocModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content admin-modal-content">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" id="deleteDocId" name="id" />
                    <div class="modal-header admin-modal-header">
                        <h5 class="modal-title">Delete Article</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">Delete <strong id="deleteDocTitle"></strong>?</p>
                    </div>
                    <div class="modal-footer admin-modal-footer">
                        <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            document.getElementById('deleteDocModal').addEventListener('show.bs.modal', function (e) {
                const b = e.relatedTarget;
                document.getElementById('deleteDocId').value = b.dataset.docId;
                document.getElementById('deleteDocTitle').textContent = b.dataset.docTitle;
            });
        </script>
    }
}
