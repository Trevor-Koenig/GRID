@page
@model GRID.Pages.Admin.Services.IndexModel

@{
    ViewData["Title"] = "Service Management";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Service Management</h2>
        <p>Manage Quick Services links and redirect tokens</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-hdd-network me-2"></i>Services</span>
                        <div class="d-flex align-items-center gap-3">
                            <span class="admin-panel-count">@Model.Links.Count total</span>
                            <button type="button" class="btn btn-primary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#createServiceModal">
                                <i class="bi bi-plus-lg me-1"></i>New Service
                            </button>
                        </div>
                    </div>

                    @if (!Model.Links.Any())
                    {
                        <div class="admin-panel-empty">
                            <i class="bi bi-hdd-network"></i>
                            <p>No services yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table admin-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Token</th>
                                        <th>Status</th>
                                        <th>Auth</th>
                                        <th>Nav</th>
                                        <th>Active</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var link in Model.Links)
                                    {
                                        var status = Model.StatusService.GetStatus(link.Token);
                                        <tr>
                                            <td class="align-middle">
                                                @if (!string.IsNullOrEmpty(link.IconClass))
                                                {
                                                    <i class="@link.IconClass me-2 text-muted"></i>
                                                }
                                                @link.Name
                                            </td>
                                            <td class="align-middle"><code class="admin-invite-code">@link.Token</code></td>
                                            <td class="align-middle">
                                                @if (status == null)
                                                {
                                                    <span class="admin-status-dot admin-status-dot--unknown" title="Not yet checked"></span>
                                                }
                                                else if (status.IsUp)
                                                {
                                                    <span class="admin-status-dot admin-status-dot--up" title="Up (@status.ResponseMs ms)"></span>
                                                }
                                                else
                                                {
                                                    <span class="admin-status-dot admin-status-dot--down" title="Down"></span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (link.RequiresAuth)
                                                {
                                                    <i class="bi bi-lock-fill text-muted" title="Requires login"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-unlock text-muted" title="Public"></i>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (link.ShowInNav)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (link.IsActive)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                                }
                                            </td>
                                            <td class="align-middle text-end">
                                                <button type="button" class="admin-action-link btn btn-link p-0"
                                                        data-bs-toggle="modal" data-bs-target="#editServiceModal"
                                                        data-service-id="@link.Id"
                                                        data-service-name="@link.Name"
                                                        data-service-token="@link.Token"
                                                        data-service-url="@link.Url"
                                                        data-service-icon="@link.IconClass"
                                                        data-service-description="@link.Description"
                                                        data-service-requiresauth="@link.RequiresAuth.ToString().ToLower()"
                                                        data-service-isactive="@link.IsActive.ToString().ToLower()"
                                                        data-service-showinnav="@link.ShowInNav.ToString().ToLower()"
                                                        data-service-showonhomepage="@link.ShowOnHomePage.ToString().ToLower()">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="admin-action-link btn btn-link p-0 ms-3"
                                                        data-bs-toggle="modal" data-bs-target="#deleteServiceModal"
                                                        data-service-id="@link.Id"
                                                        data-service-name="@link.Name">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <a asp-page="/Admin/Dashboard/Index" class="admin-back-link">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Service Modal -->
<div class="modal fade" id="createServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title"><i class="bi bi-hdd-network me-2"></i>New Service</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="createName" name="name" placeholder="Name" required />
                        <label for="createName">Name</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="createToken" name="token" placeholder="Token" required pattern="[a-z0-9]+" />
                        <label for="createToken">Token (used in /go/{token})</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="url" class="form-control" id="createUrl" name="url" placeholder="URL" required />
                        <label for="createUrl">Destination URL</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="createIcon" name="iconClass" placeholder="bi bi-hdd-network" />
                        <label for="createIcon">Icon class (optional)</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="createDescription" name="description" placeholder="Description" />
                        <label for="createDescription">Description (optional)</label>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="createRequiresAuth" name="requiresAuth" value="true" checked />
                            <label class="form-check-label" for="createRequiresAuth">Requires login</label>
                        </div>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="createShowInNav" name="showInNav" value="true" checked />
                            <label class="form-check-label" for="createShowInNav">Show in Quick Services nav</label>
                        </div>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="createShowOnHome" name="showOnHomePage" value="true" checked />
                            <label class="form-check-label" for="createShowOnHome">Show on home page</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Service Modal -->
<div class="modal fade" id="editServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Edit">
                <input type="hidden" id="editServiceId" name="id" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Service</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editName" name="name" placeholder="Name" required />
                        <label for="editName">Name</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editToken" name="token" placeholder="Token" required />
                        <label for="editToken">Token</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="url" class="form-control" id="editUrl" name="url" placeholder="URL" required />
                        <label for="editUrl">Destination URL</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editIcon" name="iconClass" placeholder="bi bi-hdd-network" />
                        <label for="editIcon">Icon class (optional)</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editDescription" name="description" placeholder="Description" />
                        <label for="editDescription">Description (optional)</label>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editRequiresAuth" name="requiresAuth" value="true" />
                            <label class="form-check-label" for="editRequiresAuth">Requires login</label>
                        </div>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editIsActive" name="isActive" value="true" />
                            <label class="form-check-label" for="editIsActive">Active</label>
                        </div>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editShowInNav" name="showInNav" value="true" />
                            <label class="form-check-label" for="editShowInNav">Show in Quick Services nav</label>
                        </div>
                    </div>
                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editShowOnHome" name="showOnHomePage" value="true" />
                            <label class="form-check-label" for="editShowOnHome">Show on home page</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Service Modal -->
<div class="modal fade" id="deleteServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" id="deleteServiceId" name="id" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Delete Service</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Delete <strong id="deleteServiceName"></strong>?</p>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('editServiceModal').addEventListener('show.bs.modal', function (e) {
            const b = e.relatedTarget;
            document.getElementById('editServiceId').value = b.dataset.serviceId;
            document.getElementById('editName').value = b.dataset.serviceName;
            document.getElementById('editToken').value = b.dataset.serviceToken;
            document.getElementById('editUrl').value = b.dataset.serviceUrl;
            document.getElementById('editIcon').value = b.dataset.serviceIcon || '';
            document.getElementById('editDescription').value = b.dataset.serviceDescription || '';
            document.getElementById('editRequiresAuth').checked = b.dataset.serviceRequiresauth === 'true';
            document.getElementById('editIsActive').checked = b.dataset.serviceIsactive === 'true';
            document.getElementById('editShowInNav').checked = b.dataset.serviceShowinnav === 'true';
            document.getElementById('editShowOnHome').checked = b.dataset.serviceShowonhomepage === 'true';
        });

        document.getElementById('deleteServiceModal').addEventListener('show.bs.modal', function (e) {
            const b = e.relatedTarget;
            document.getElementById('deleteServiceId').value = b.dataset.serviceId;
            document.getElementById('deleteServiceName').textContent = b.dataset.serviceName;
        });
    </script>
}
