@page
@model GRID.Pages.Admin.Users.EditModel

@{
    ViewData["Title"] = "Edit User";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Edit User</h2>
        <p>@Model.Email</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-shield-lock me-2"></i>Role Assignment</span>
                    </div>
                    <div class="admin-detail-body">
                        <form method="post">
                            <input type="hidden" asp-for="UserId" />
                            <input type="hidden" asp-for="Email" />
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                            <div class="admin-detail-row">
                                <span class="admin-detail-label">User</span>
                                <span class="admin-detail-value">@Model.Email</span>
                            </div>

                            <div class="admin-detail-row align-items-start">
                                <span class="admin-detail-label pt-2">Role</span>
                                <div class="admin-detail-value">
                                    <div class="admin-role-options">
                                        @foreach (var role in Model.AvailableRoles)
                                        {
                                            <label class="admin-role-option">
                                                <input type="radio" asp-for="SelectedRole" value="@role" />
                                                <span class="admin-role-badge admin-role-badge--@role.ToLower()">@role</span>
                                            </label>
                                        }
                                        <label class="admin-role-option">
                                            <input type="radio" asp-for="SelectedRole" value="" />
                                            <span class="text-muted fst-italic">None</span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="admin-panel-footer">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="bi bi-check-lg me-1"></i>Save
                                </button>
                                <a asp-page="./Details" asp-route-id="@Model.UserId" class="admin-back-link ms-3">
                                    <i class="bi bi-arrow-left me-1"></i>Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
