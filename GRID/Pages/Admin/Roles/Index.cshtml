@page
@model GRID.Pages.Admin.Roles.IndexModel

@{
    ViewData["Title"] = "Role Management";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Role Management</h2>
        <p>Create and manage user roles</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <partial name="_ManagementNav" model="@("Roles")" />
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-shield me-2"></i>Roles</span>
                        <button type="button" class="btn btn-primary btn-sm"
                                data-bs-toggle="modal" data-bs-target="#createRoleModal">
                            <i class="bi bi-plus-lg me-1"></i>New Role
                        </button>
                    </div>

                    @if (!Model.Roles.Any())
                    {
                        <div class="admin-panel-empty">
                            <i class="bi bi-shield-x"></i>
                            <p>No roles defined.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var role in Model.Roles)
                        {
                            <div class="admin-detail-row">
                                <span class="admin-role-badge admin-role-badge--@role.Name.ToLower()">@role.Name</span>
                                <span class="text-muted ms-2" style="font-size:0.8rem;">@role.UserCount user(s)</span>
                                <form method="post" asp-page-handler="Delete" class="ms-auto">
                                    <input type="hidden" name="roleId" value="@role.Id" />
                                    <button type="button" class="admin-action-link btn btn-link p-0"
                                            data-bs-toggle="modal" data-bs-target="#deleteRoleModal"
                                            data-role-name="@role.Name"
                                            data-role-id="@role.Id"
                                            data-user-count="@role.UserCount">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    }
                </div>

                <div class="mt-3">
                    <a asp-page="/Admin/Dashboard/Index" class="admin-back-link"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Role Modal -->
<div class="modal fade" id="createRoleModal" tabindex="-1" aria-labelledby="createRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title" id="createRoleModalLabel">
                        <i class="bi bi-shield-plus me-2"></i>New Role
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating">
                        <input type="text" class="form-control" id="roleName" name="roleName"
                               placeholder="Role name" required autocomplete="off" />
                        <label for="roleName">Role Name</label>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Role Modal -->
<div class="modal fade" id="deleteRoleModal" tabindex="-1" aria-labelledby="deleteRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" id="deleteRoleId" name="roleId" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title" id="deleteRoleModalLabel">
                        <i class="bi bi-trash me-2"></i>Delete Role
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-1">Delete the <strong id="deleteRoleName"></strong> role?</p>
                    <p class="text-warning mb-0" id="deleteRoleWarning" style="font-size:0.85rem; display:none;">
                        <i class="bi bi-exclamation-triangle me-1"></i>This role is assigned to users and will be removed from them.
                    </p>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteRoleModal').addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            document.getElementById('deleteRoleId').value = btn.dataset.roleId;
            document.getElementById('deleteRoleName').textContent = btn.dataset.roleName;
            const userCount = parseInt(btn.dataset.userCount, 10);
            document.getElementById('deleteRoleWarning').style.display = userCount > 0 ? '' : 'none';
        });
    </script>
}
