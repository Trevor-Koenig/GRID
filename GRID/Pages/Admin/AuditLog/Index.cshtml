@page
@model GRID.Pages.Admin.AuditLog.IndexModel

@{
    ViewData["Title"] = "Audit Log";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Audit Log</h2>
        <p>Admin actions and visitor page views</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-11">

                <!-- Filter + Search bar -->
                <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
                    <a asp-page="Index" asp-route-filter="all" asp-route-search="@Model.Search"
                       class="btn btn-sm @(Model.Filter == "all" ? "btn-primary" : "btn-outline-secondary")">All</a>
                    <a asp-page="Index" asp-route-filter="admin" asp-route-search="@Model.Search"
                       class="btn btn-sm @(Model.Filter == "admin" ? "btn-primary" : "btn-outline-secondary")">
                        <i class="bi bi-shield me-1"></i>Admin Actions
                    </a>
                    <a asp-page="Index" asp-route-filter="pageviews" asp-route-search="@Model.Search"
                       class="btn btn-sm @(Model.Filter == "pageviews" ? "btn-primary" : "btn-outline-secondary")">
                        <i class="bi bi-eye me-1"></i>Page Views
                    </a>
                    <form method="get" class="d-flex gap-2 ms-auto">
                        <input type="hidden" name="filter" value="@Model.Filter" />
                        <input type="text" name="search" value="@Model.Search"
                               class="form-control form-control-sm" placeholder="Search actor or IP…"
                               style="min-width:220px;" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
                        @if (!string.IsNullOrWhiteSpace(Model.Search))
                        {
                            <a asp-page="Index" asp-route-filter="@Model.Filter" class="btn btn-sm btn-outline-danger" title="Clear search"><i class="bi bi-x-lg"></i></a>
                        }
                    </form>
                </div>

                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-journal-text me-2"></i>Activity</span>
                        <span class="admin-panel-count">@Model.TotalCount entries</span>
                    </div>

                    @if (!Model.Logs.Any())
                    {
                        <div class="admin-panel-empty">
                            <i class="bi bi-journal"></i>
                            <p>No activity recorded yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table admin-table">
                                <thead>
                                    <tr>
                                        <th>Time</th>
                                        <th>Visitor / Actor</th>
                                        <th>Action</th>
                                        <th>Page / Entity</th>
                                        <th>Duration</th>
                                        <th>IP</th>
                                        <th>Status</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in Model.Logs)
                                    {
                                        var isPageView = log.Action == "PageView";
                                        <tr class="@(isPageView ? "" : "table-active")">
                                            <td class="align-middle text-muted" style="font-size:0.8rem;white-space:nowrap;">
                                                @log.Timestamp.ToLocalTime().ToString("MMM d, h:mm tt")
                                            </td>
                                            <td class="align-middle" style="font-size:0.875rem;">
                                                @if (log.ActorEmail != null)
                                                {
                                                    <span>@log.ActorEmail</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">Anonymous</span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (isPageView)
                                                {
                                                    <span class="badge" style="background:color-mix(in srgb,var(--accent-color) 15%,transparent);color:var(--accent-color);font-weight:500;">
                                                        <i class="bi bi-eye me-1"></i>View
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge" style="background:color-mix(in srgb,#e74c3c 15%,transparent);color:#e74c3c;font-weight:500;">
                                                        <i class="bi bi-shield me-1"></i>@log.Action
                                                    </span>
                                                }
                                            </td>
                                            <td class="align-middle text-muted" style="font-size:0.875rem;">
                                                @if (isPageView)
                                                {
                                                    <code style="font-size:0.8rem;">@log.EntityId</code>
                                                }
                                                else if (!string.IsNullOrEmpty(log.EntityType))
                                                {
                                                    <span>@log.EntityType</span>
                                                    @if (!string.IsNullOrEmpty(log.EntityId))
                                                    {
                                                        <code class="ms-1" style="font-size:0.8rem;">@log.EntityId</code>
                                                    }
                                                }
                                            </td>
                                            <td class="align-middle text-muted" style="font-size:0.875rem;">
                                                @if (isPageView && log.DurationSeconds.HasValue)
                                                {
                                                    var d = log.DurationSeconds.Value;
                                                    var display = d >= 60 ? $"{d / 60}m {d % 60}s" : $"{d}s";
                                                    <span>@display</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="align-middle text-muted" style="font-size:0.8rem;">
                                                @if (log.IpAddress != null)
                                                {
                                                    <code style="font-size:0.8rem;">@log.IpAddress</code>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="align-middle" style="font-size:0.875rem;">
                                                @if (log.HttpStatus.HasValue)
                                                {
                                                    var sc = log.HttpStatus.Value;
                                                    var statusColor = sc >= 500 ? "#e74c3c" : sc >= 400 ? "#e67e22" : sc >= 300 ? "#3498db" : "#27ae60";
                                                    <span class="badge" style="background:color-mix(in srgb,@statusColor 15%,transparent);color:@statusColor;font-weight:500;">@sc</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="align-middle text-muted" style="font-size:0.875rem;">@log.Details</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div class="text-muted" style="font-size:0.85rem;">
                            Showing @((Model.Page - 1) * GRID.Pages.Admin.AuditLog.IndexModel.PageSize + 1)–@(Math.Min(Model.Page * GRID.Pages.Admin.AuditLog.IndexModel.PageSize, Model.TotalCount)) of @Model.TotalCount
                        </div>
                        <div class="d-flex gap-1">
                            @if (Model.Page > 1)
                            {
                                <a asp-page="Index" asp-route-page="@(Model.Page - 1)" asp-route-filter="@Model.Filter" asp-route-search="@Model.Search"
                                   class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-left"></i></a>
                            }
                            @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                            {
                                <a asp-page="Index" asp-route-page="@p" asp-route-filter="@Model.Filter" asp-route-search="@Model.Search"
                                   class="btn btn-sm @(p == Model.Page ? "btn-primary" : "btn-outline-secondary")">@p</a>
                            }
                            @if (Model.Page < Model.TotalPages)
                            {
                                <a asp-page="Index" asp-route-page="@(Model.Page + 1)" asp-route-filter="@Model.Filter" asp-route-search="@Model.Search"
                                   class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-right"></i></a>
                            }
                        </div>
                    </div>
                }

                <div class="mt-3">
                    <a asp-page="/Admin/Dashboard/Index" class="admin-back-link">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
