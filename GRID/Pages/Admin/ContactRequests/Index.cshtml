@page
@model GRID.Pages.Admin.ContactRequests.IndexModel

@{
    ViewData["Title"] = "Contact Requests";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Contact Requests</h2>
        <p>Messages submitted through the contact form</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-11">

                <partial name="_ManagementNav" model="@("Contacts")" />

                <partial name="_StatusMessage" for="StatusMessage" />

                <!-- Filter Bar -->
                <form method="get" class="d-flex gap-2 mb-3 flex-wrap">
                    <input type="text" name="search" class="form-control form-control-sm" style="max-width:240px;"
                           placeholder="Search name, email, subject..." value="@Model.Search" />
                    <select name="status" class="form-select form-select-sm" style="max-width:160px;"
                            onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.Status))">All</option>
                        <option value="pending" selected="@(Model.Status == "pending")">Pending</option>
                        <option value="responded" selected="@(Model.Status == "responded")">Responded</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Filter</button>
                    @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status))
                    {
                        <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">Clear</a>
                    }
                </form>

                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-envelope me-2"></i>Requests</span>
                        <span class="admin-panel-count">@Model.Requests.Count shown</span>
                    </div>

                    @if (!Model.Requests.Any())
                    {
                        <div class="admin-panel-empty">
                            <i class="bi bi-envelope-open"></i>
                            <p>No contact requests found.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table admin-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Subject</th>
                                        <th>Submitted</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Requests)
                                    {
                                        <tr>
                                            <td class="align-middle">@item.Name</td>
                                            <td class="align-middle text-muted" style="font-size:0.875rem;">@item.Email</td>
                                            <td class="align-middle">@item.Subject</td>
                                            <td class="align-middle text-muted" style="font-size:0.875rem;">
                                                @item.SubmittedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                            </td>
                                            <td class="align-middle">
                                                @if (item.IsResponded)
                                                {
                                                    <span class="admin-role-badge admin-role-badge--user">Responded</span>
                                                }
                                                else
                                                {
                                                    <span class="admin-role-badge admin-role-badge--inactive">Pending</span>
                                                }
                                            </td>
                                            <td class="align-middle text-end">
                                                <button type="button" class="admin-action-link btn btn-link p-0"
                                                        data-bs-toggle="modal" data-bs-target="#viewMessageModal"
                                                        data-request-id="@item.Id"
                                                        data-request-name="@item.Name"
                                                        data-request-email="@item.Email"
                                                        data-request-subject="@item.Subject"
                                                        data-request-message="@item.Message"
                                                        title="View message">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                <button type="button" class="admin-action-link btn btn-link p-0 ms-3"
                                                        data-bs-toggle="modal" data-bs-target="#replyModal"
                                                        data-request-id="@item.Id"
                                                        data-request-name="@item.Name"
                                                        data-request-email="@item.Email"
                                                        data-request-subject="@item.Subject"
                                                        title="Reply">
                                                    <i class="bi bi-reply"></i>
                                                </button>
                                                @if (!item.IsResponded)
                                                {
                                                    <form method="post" asp-page-handler="Respond" class="d-inline ms-3">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="admin-action-link btn btn-link p-0" title="Mark as responded">
                                                            <i class="bi bi-check-circle"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form method="post" asp-page-handler="Unrespond" class="d-inline ms-3">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="admin-action-link btn btn-link p-0" title="Unmark as responded">
                                                            <i class="bi bi-arrow-counterclockwise"></i>
                                                        </button>
                                                    </form>
                                                }
                                                <button type="button" class="admin-action-link btn btn-link p-0 ms-3"
                                                        data-bs-toggle="modal" data-bs-target="#deleteRequestModal"
                                                        data-request-id="@item.Id"
                                                        data-request-name="@item.Name"
                                                        title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <a asp-page="/Admin/Dashboard/Index" class="admin-back-link"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- View Message Modal -->
<div class="modal fade" id="viewMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content admin-modal-content">
            <div class="modal-header admin-modal-header">
                <h5 class="modal-title"><i class="bi bi-envelope me-2"></i><span id="modalSubject"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="admin-detail-label">From</div>
                    <div class="admin-detail-value">
                        <span id="modalName"></span>
                        <span class="text-muted ms-2" style="font-size:0.875rem;" id="modalEmail"></span>
                    </div>
                </div>
                <div>
                    <div class="admin-detail-label">Message</div>
                    <div class="admin-detail-value" id="modalMessage" style="white-space:pre-wrap;"></div>
                </div>
            </div>
            <div class="modal-footer admin-modal-footer">
                <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Reply">
                <input type="hidden" id="replyRequestId" name="id" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title"><i class="bi bi-reply me-2"></i>Reply to <span id="replyName"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3" style="font-size:0.85rem;">
                        Replying to <strong id="replyEmail"></strong> — Re: <em id="replySubject"></em>
                    </p>
                    <div class="form-floating">
                        <textarea class="form-control" id="replyMessage" name="replyMessage"
                                  placeholder="Your reply..." style="height:150px;" required></textarea>
                        <label for="replyMessage">Your reply</label>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-send me-1"></i>Send Reply
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Request Modal -->
<div class="modal fade" id="deleteRequestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" id="deleteRequestId" name="id" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Delete Request</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Delete request from <strong id="deleteRequestName"></strong>?</p>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('viewMessageModal').addEventListener('show.bs.modal', function (e) {
            const b = e.relatedTarget;
            document.getElementById('modalSubject').textContent = b.dataset.requestSubject;
            document.getElementById('modalName').textContent = b.dataset.requestName;
            document.getElementById('modalEmail').textContent = b.dataset.requestEmail;
            document.getElementById('modalMessage').textContent = b.dataset.requestMessage;
        });

        document.getElementById('replyModal').addEventListener('show.bs.modal', function (e) {
            const b = e.relatedTarget;
            document.getElementById('replyRequestId').value = b.dataset.requestId;
            document.getElementById('replyName').textContent = b.dataset.requestName;
            document.getElementById('replyEmail').textContent = b.dataset.requestEmail;
            document.getElementById('replySubject').textContent = b.dataset.requestSubject;
            document.getElementById('replyMessage').value = '';
        });

        document.getElementById('deleteRequestModal').addEventListener('show.bs.modal', function (e) {
            const b = e.relatedTarget;
            document.getElementById('deleteRequestId').value = b.dataset.requestId;
            document.getElementById('deleteRequestName').textContent = b.dataset.requestName;
        });
    </script>
}
