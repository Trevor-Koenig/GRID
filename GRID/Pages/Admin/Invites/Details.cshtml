@page
@model GRID.Pages.Admin.Invites.DetailsModel

@{
    ViewData["Title"] = "Invite Details";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Invite Details</h2>
        <p><code class="admin-invite-code">@Model.Invite.Code</code></p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-ticket-perforated me-2"></i>Invite Info</span>
                        @if (Model.Invite.IsActive)
                        {
                            <span class="admin-role-badge admin-role-badge--user">Active</span>
                        }
                        else
                        {
                            <span class="admin-role-badge admin-role-badge--inactive">Inactive</span>
                        }
                    </div>
                    <div class="admin-detail-body">
                        <div class="admin-detail-row">
                            <span class="admin-detail-label">Code</span>
                            <span class="admin-detail-value"><code class="admin-invite-code">@Model.Invite.Code</code></span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label">Role</span>
                            <span class="admin-detail-value">
                                @if (!string.IsNullOrEmpty(Model.Invite.Role))
                                {
                                    <span class="admin-role-badge admin-role-badge--@Model.Invite.Role.ToLower()">@Model.Invite.Role</span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">None</span>
                                }
                            </span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label">Uses</span>
                            <span class="admin-detail-value">
                                @Model.Invite.CurrentUses
                                @if (Model.Invite.MaxUses.HasValue)
                                {
                                    <span class="text-muted">/ @Model.Invite.MaxUses</span>
                                }
                                else
                                {
                                    <span class="text-muted">/ ∞</span>
                                }
                                @if (Model.Invite.IsSingleUse)
                                {
                                    <span class="ms-2 text-muted" style="font-size:0.8rem;">(single use)</span>
                                }
                            </span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label">Email</span>
                            <span class="admin-detail-value">
                                @if (string.IsNullOrEmpty(Model.Invite.Email))
                                {
                                    <span class="text-muted fst-italic">Any</span>
                                }
                                else
                                {
                                    @Model.Invite.Email
                                }
                            </span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label">Created</span>
                            <span class="admin-detail-value">@Model.Invite.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label">Expires</span>
                            <span class="admin-detail-value">
                                @if (Model.Invite.ExpiresAt.HasValue)
                                {
                                    @Model.Invite.ExpiresAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Never</span>
                                }
                            </span>
                        </div>
                    </div>
                    <div class="admin-panel-footer">
                        <a asp-page="./Edit" asp-route-id="@Model.Invite.Id" class="btn btn-primary btn-sm">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a asp-page="./Index" class="admin-back-link ms-3">
                            <i class="bi bi-arrow-left me-1"></i>Back to Invites
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
