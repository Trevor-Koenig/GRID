@page
@model GRID.Pages.Admin.Invites.IndexModel

@{
    ViewData["Title"] = "Invite Management";
}

<section class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Invite Management</h2>
        <p>Create and manage invite codes</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <div class="admin-panel-card">
                    <div class="admin-panel-header">
                        <span><i class="bi bi-ticket-perforated me-2"></i>Invites</span>
                        <div class="d-flex align-items-center gap-3">
                            <span class="admin-panel-count">@Model.Invite.Count total</span>
                            <button type="button" class="btn btn-primary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#createInviteModal">
                                <i class="bi bi-plus-lg me-1"></i>New Invite
                            </button>
                        </div>
                    </div>

                    @if (!Model.Invite.Any())
                    {
                        <div class="admin-panel-empty">
                            <i class="bi bi-ticket-detailed"></i>
                            <p>No invites yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table admin-table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Role</th>
                                        <th>Uses</th>
                                        <th>Email</th>
                                        <th>Redeemed By</th>
                                        <th>Active</th>
                                        <th>Expires</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Invite)
                                    {
                                        <tr>
                                            <td class="align-middle">
                                                <code class="admin-invite-code">@item.Code</code>
                                            </td>
                                            <td class="align-middle">
                                                @if (!string.IsNullOrEmpty(item.Role))
                                                {
                                                    <span class="admin-role-badge admin-role-badge--@item.Role.ToLower()">@item.Role</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">None</span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (item.MaxUses == null)
                                                {
                                                    <span>@item.CurrentUses <span class="text-muted">/ ∞</span></span>
                                                }
                                                else
                                                {
                                                    <span>@item.CurrentUses <span class="text-muted">/ @item.MaxUses</span></span>
                                                }
                                            </td>
                                            <td class="align-middle text-muted" style="font-size:0.875rem;">
                                                @(string.IsNullOrEmpty(item.Email) ? "—" : item.Email)
                                            </td>
                                            <td class="align-middle text-muted" style="font-size:0.8rem;">
                                                @if (Model.RedeemerEmails.TryGetValue(item.Id, out var redeemers) && redeemers.Any())
                                                {
                                                    @string.Join(", ", redeemers)
                                                }
                                                else
                                                {
                                                    <span>—</span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (item.IsActive)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                                }
                                            </td>
                                            <td class="align-middle" style="font-size:0.875rem;">
                                                @if (item.ExpiresAt.HasValue)
                                                {
                                                    var daysLeft = (item.ExpiresAt.Value - DateTime.UtcNow).TotalDays;
                                                    if (daysLeft <= 3)
                                                    {
                                                        <span class="text-danger fw-semibold" title="Expiring soon!">
                                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>@item.ExpiresAt.Value.ToLocalTime().ToString("MMM d, yyyy")
                                                        </span>
                                                    }
                                                    else if (daysLeft <= 7)
                                                    {
                                                        <span class="text-warning fw-semibold" title="Expiring this week">
                                                            @item.ExpiresAt.Value.ToLocalTime().ToString("MMM d, yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">@item.ExpiresAt.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Never</span>
                                                }
                                            </td>
                                            <td class="align-middle text-end">
                                                <a asp-page="./Details" asp-route-id="@item.Id" class="admin-action-link">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a asp-page="./Edit" asp-route-id="@item.Id" class="admin-action-link ms-3">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button type="button" class="admin-action-link btn btn-link p-0 ms-3"
                                                        data-bs-toggle="modal" data-bs-target="#deleteInviteModal"
                                                        data-invite-id="@item.Id"
                                                        data-invite-code="@item.Code">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <a asp-page="/Admin/Users/Index" class="admin-back-link">
                        <i class="bi bi-people me-1"></i>Manage Users
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Invite Modal -->
<div class="modal fade" id="createInviteModal" tabindex="-1" aria-labelledby="createInviteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title" id="createInviteModalLabel">
                        <i class="bi bi-ticket-perforated me-2"></i>New Invite
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3" style="font-size:0.85rem;">
                        A unique code will be generated automatically.
                    </p>

                    <div class="form-floating mb-3">
                        <select class="form-select" id="createRole" name="role">
                            <option value="">— None —</option>
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <label for="createRole">Role</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="createEmail" name="email" placeholder="optional" />
                        <label for="createEmail">Restrict to email (optional)</label>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="createSingleUse" name="isSingleUse" value="true" checked />
                            <label class="form-check-label" for="createSingleUse">Single use</label>
                        </div>
                    </div>

                    <div class="form-floating mb-3" id="maxUsesGroup" style="display:none;">
                        <input type="number" class="form-control" id="createMaxUses" name="maxUses" min="1" value="1" />
                        <label for="createMaxUses">Max uses</label>
                    </div>

                    <div class="form-floating mb-1">
                        <input type="datetime-local" class="form-control" id="createExpiresAt" name="expiresAt" />
                        <label for="createExpiresAt">Expires at (optional)</label>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Invite Modal -->
<div class="modal fade" id="deleteInviteModal" tabindex="-1" aria-labelledby="deleteInviteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content admin-modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" id="deleteInviteId" name="id" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title" id="deleteInviteModalLabel">
                        <i class="bi bi-trash me-2"></i>Delete Invite
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Delete invite <code id="deleteInviteCode" class="admin-invite-code"></code>?</p>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn btn-sm admin-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Delete modal population
        document.getElementById('deleteInviteModal').addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            document.getElementById('deleteInviteId').value = btn.dataset.inviteId;
            document.getElementById('deleteInviteCode').textContent = btn.dataset.inviteCode;
        });

        // Toggle max uses field based on single-use checkbox
        const singleUseToggle = document.getElementById('createSingleUse');
        const maxUsesGroup = document.getElementById('maxUsesGroup');
        singleUseToggle.addEventListener('change', function () {
            maxUsesGroup.style.display = this.checked ? 'none' : '';
        });
    </script>
}
